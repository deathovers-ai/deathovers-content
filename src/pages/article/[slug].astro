---
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

// 1. Generate local entry paths dynamically based on existing markdown filenames
export async function getStaticPaths() {
  const postEntries = await getCollection('posts');
  return postEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{entry.data.title} — DeathOvers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --pitch-black: #080A0F;
      --blood-red: #E8003A;
      --bail-amber: #F5A623;
      --crease-white: #F0F2F5;
      --outfield: #16191F;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--pitch-black);
      color: var(--crease-white);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      padding: 24px;
    }
    .page { width: 100%; max-width: 900px; background: var(--pitch-black); }
    .content-area { padding: 32px 24px; }
    .meta-data { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--blood-red); margin-bottom: 12px; }
    .article-title { font-family: 'Bebas Neue', sans-serif; font-size: 42px; line-height: 1.1; margin-bottom: 24px; color: #fff; border-bottom: 2px solid var(--blood-red); padding-bottom: 12px; }
    
    /* Target generated inner markdown markup tags explicitly */
    .prose { font-size: 15px; line-height: 1.6; color: rgba(240,242,245,0.8); }
    .prose h3 { font-family: 'Bebas Neue', sans-serif; font-size: 24px; color: #fff; margin: 28px 0 12px; }
    .prose p { margin-bottom: 16px; }
    .prose table { width: 100%; border-collapse: collapse; margin: 20px 0; font-family: 'JetBrains Mono', monospace; font-size: 12px; background: rgba(0,0,0,0.2); }
    .prose th { border-bottom: 2px solid rgba(255,255,255,0.1); padding: 8px; text-align: left; color: var(--bail-amber); }
    .prose td { padding: 8px; border-bottom: 1px solid rgba(255,255,255,0.02); }

    .footer { padding: 20px 24px; border-top: 1px solid rgba(240,242,245,0.06); display: flex; justify-content: space-between; margin-top: 60px; }
    .footer span { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(240,242,245,0.3); }
  </style>
</head>
<body>
  <div class="page">
    <Navbar />
    
    <div class="content-area">
      <div class="meta-data">{entry.data.category} · {entry.data.date}</div>
      <h1 class="article-title">{entry.data.title}</h1>
      
      <div class="prose">
        <Content />
      </div>
    </div>

    <div class="footer">
      <span>© 2026 DEATHOVERS</span>
      <span>POWERED BY GROQ + HIGHLIGHTLY</span>
    </div>
  </div>
</body>
</html>
