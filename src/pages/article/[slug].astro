---
// src/pages/article/[slug].astro
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

// Tell Astro to map URLs for every markdown file it finds
export async function getStaticPaths() {
  const postEntries = await getCollection('posts');
  return postEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Base title={`${entry.data.title || 'Match Report'} — DeathOvers`}>
  <Navbar />
  
  <div class="content-area">
    <div class="meta-data">{entry.data.category || 'PRESS-BOX'} · {entry.data.date || 'LATEST'}</div>
    <h1 class="article-title">{entry.data.title}</h1>
    
    <div class="prose">
      {/* This automatically renders the markdown text generated by n8n */}
      <Content />
    </div>
  </div>
  
  <div class="footer">
    <span>© 2026 DEATHOVERS</span>
    <span>POWERED BY GROQ + N8N</span>
  </div>
</Base>

<style>
  .content-area { 
    padding: 32px 24px; 
    max-width: 800px;
    margin: 0 auto;
  }
  .meta-data { 
    font-family: 'JetBrains Mono', monospace; 
    font-size: 11px; 
    color: var(--blood-red); 
    margin-bottom: 12px; 
    text-transform: uppercase; 
  }
  .article-title { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 42px; 
    line-height: 1.1; 
    margin-bottom: 24px; 
    color: #fff; 
    border-bottom: 2px solid var(--blood-red); 
    padding-bottom: 12px; 
  }
  
  /* Critical: We use :global() so Astro applies these styles to the injected Markdown */
  .prose { 
    font-size: 15px; 
    line-height: 1.6; 
    color: rgba(240,242,245,0.8); 
  }
  .prose :global(h2), .prose :global(h3) { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 24px; 
    color: #fff; 
    margin: 28px 0 12px; 
  }
  .prose :global(p) { margin-bottom: 16px; }
  .prose :global(table) { 
    width: 100%; 
    border-collapse: collapse; 
    margin: 20px 0; 
    font-family: 'JetBrains Mono', monospace; 
    font-size: 12px; 
    background: rgba(0,0,0,0.2); 
  }
  .prose :global(th) { 
    border-bottom: 2px solid rgba(255,255,255,0.1); 
    padding: 8px; 
    text-align: left; 
    color: var(--bail-amber); 
  }
  .prose :global(td) { 
    padding: 8px; 
    border-bottom: 1px solid rgba(255,255,255,0.02); 
  }
  
  .footer { 
    padding: 20px 24px; 
    border-top: 1px solid rgba(240,242,245,0.06); 
    display: flex; 
    justify-content: space-between; 
    margin-top: 60px; 
  }
  .footer span { 
    font-family: 'JetBrains Mono', monospace; 
    font-size: 10px; 
    color: rgba(240,242,245,0.3); 
  }
</style>
