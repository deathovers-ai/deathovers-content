---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import LiveCarousel from '../components/LiveCarousel.jsx';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
---

<Base title="DeathOvers — Advanced Analytics">
  <Navbar />
  
  <LiveCarousel client:load />

  <div class="featured-wrap">
    <a href="#" class="featured-card">
      <div class="featured-tag">PRESS BOX · FEATURED</div>
      <div class="featured-title">HOW RASHID KHAN TURNED THE QUALIFIER ON ITS HEAD</div>
      <div class="featured-desc">AI breakdown of the 17th-over spell that swung GT v KKR — powerplay economy, matchup data, and the turning point in numbers.</div>
    </a>
  </div>

  <div class="content-area">
    <h2 class="section-title">MATCH POST-MORTEMS</h2>
    {allPosts.length === 0 ? (
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--bail-amber); text-align: center; padding: 40px; border: 1px dashed rgba(240,242,245,0.2);">
        [ AWAITING LIVE DATA FROM SECURE UPLINK... ]
      </div>
    ) : (
      <div style="display: flex; flex-direction: column;">
        {allPosts.map((post) => (
          <div class="article-card">
            <div class="meta-data">{post.data.category || 'ANALYSIS'} · {post.data.date || 'LATEST'}</div>
            <a href={`/article/${post.slug}`} style="text-decoration: none;">
              <h3 class="card-title">{post.data.title || 'In-Play Report'}</h3>
            </a>
            <p class="card-excerpt">{post.body.substring(0, 160)}...</p>
            <a href={`/article/${post.slug}`} class="read-more">DECRYPT FULL REPORT →</a>
          </div>
        ))}
      </div>
    )}
  </div>
  
  <div class="footer">
    <span>© 2026 DEATHOVERS</span>
    <span>POWERED BY GROQ + N8N</span>
  </div>
</Base>

<style>
  .featured-wrap { padding: 24px 24px 24px; }
  .featured-card { background: var(--outfield); border: 1px solid rgba(232,0,58,0.2); border-radius: 4px; padding: 24px; position: relative; cursor: pointer; text-decoration: none; display: block; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .featured-card:hover { transform: translateY(-2px); box-shadow: 0 6px 24px var(--hover-glow); }
  .featured-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--blood-red), var(--bail-amber)); }
  .featured-tag { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--blood-red); letter-spacing: 0.05em; font-weight: bold; }
  .featured-title { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--crease-white); margin: 10px 0 8px; letter-spacing: 0.01em; line-height: 1.15; }
  .featured-desc { font-size: 13px; color: rgba(240,242,245,0.6); line-height: 1.6; }

  .content-area { padding: 32px 24px; }
  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 32px; color: #fff; border-bottom: 2px solid var(--blood-red); padding-bottom: 12px; margin-bottom: 32px; }
  
  .article-card { background: var(--outfield); border: 1px solid rgba(240,242,245,0.08); padding: 24px; margin-bottom: 16px; transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease; border-radius: 4px; }
  .article-card:hover { transform: translateY(-2px); border-color: var(--blood-red); box-shadow: 0 4px 20px var(--hover-glow); }
  .meta-data { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--blood-red); margin-bottom: 12px; text-transform: uppercase; font-weight: bold; }
  .card-title { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: #fff; margin-bottom: 12px; }
  .card-excerpt { font-size: 14px; line-height: 1.6; color: rgba(240,242,245,0.7); margin-bottom: 16px; }
  .read-more { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--bail-amber); text-decoration: none; font-weight: bold; transition: color 0.2s; }
  .read-more:hover { color: #fff; }

  .footer { padding: 20px 24px; border-top: 1px solid rgba(240,242,245,0.06); display: flex; justify-content: space-between; margin-top: 20px; }
  .footer span { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(240,242,245,0.3); }
</style>
