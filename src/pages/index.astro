---
// src/pages/index.astro
import { getCollection } from 'astro:content';

// Fetch all the markdown files n8n creates in src/content/posts/
const allPosts = await getCollection('posts');
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DeathOvers Analytics</title>
  </head>
  <body style="background-color: #07080a; color: white; padding: 2rem; font-family: system-ui, sans-serif; line-height: 1.6;">
    
    <main style="max-width: 800px; margin: 0 auto;">
      
      <header style="border-bottom: 1px solid #1e2330; padding-bottom: 1rem; margin-bottom: 2rem;">
        <h1 style="text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0.2rem;">Death Overs</h1>
        <p style="color: #4f5e7c; font-size: 0.9rem; margin-top: 0;">Automated Cricket Analytics Engine</p>
      </header>

      <section>
        <h2 style="font-size: 1.2rem; color: #a3b3d2; margin-bottom: 1.5rem;">Match Post-Mortem Reports</h2>
        
        {allPosts.length === 0 ? (
          <div style="padding: 2rem; border: 1px dashed #1e2330; border-radius: 8px; text-align: center; color: #4f5e7c;">
            Waiting for n8n to publish the first match report...
          </div>
        ) : (
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            {allPosts.map((post) => (
              <article style="background-color: #11141d; padding: 1.5rem; border-radius: 8px; border: 1px solid #1e2330;">
                <h3 style="margin-top: 0; color: #60a5fa;">{post.data.title || 'Match Analysis'}</h3>
                <p style="color: #a3b3d2; font-size: 0.9rem;">
                  {post.body.substring(0, 150)}...
                </p>
                <a href={`/posts/${post.slug}`} style="color: #34d399; text-decoration: none; font-size: 0.85rem; font-weight: bold;">READ FULL REPORT →</a>
              </article>
            ))}
          </div>
        )}
      </section>

    </main>
  </body>
</html>
