---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import LiveCarousel from '../components/LiveCarousel.jsx';
import { getCollection } from 'astro:content';

// Fetch historical match reports from n8n pipeline
const allPosts = await getCollection('posts');
---

<Base title="DeathOvers — Automated Analytics">
  <Navbar />
  
  <div class="content-area">
    
    {/* REACT COMPONENT FOR LIVE REALTIME STREAMING */}
    <LiveCarousel client:load />

    {/* POST-MORTEM REPORTS GENERATED BY N8N */}
    <h2 class="section-title" style="margin-top: 40px;">MATCH POST-MORTEMS</h2>
    
    {allPosts.length === 0 ? (
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--bail-amber); text-align: center; padding: 40px; border: 1px dashed rgba(240,242,245,0.2);">
        [ AWAITING LIVE DATA FROM SECURE UPLINK... ]
      </div>
    ) : (
      <div style="display: flex; flex-direction: column;">
        {allPosts.map((post) => (
          <div class="article-card">
            <div class="meta-data">{post.data.category || 'ANALYSIS'} · {post.data.date || 'LATEST'}</div>
            {/* Fix applied here: mapping to the /article/ slug */}
            <a href={`/article/${post.slug}`} style="text-decoration: none;">
              <h3 class="card-title">{post.data.title || 'In-Play Report'}</h3>
            </a>
            <p class="card-excerpt">
              {post.body.substring(0, 160)}...
            </p>
            {/* Fix applied here: mapping to the /article/ slug */}
            <a href={`/article/${post.slug}`} class="read-more">DECRYPT FULL REPORT →</a>
          </div>
        ))}
      </div>
    )}
  </div>
  
  <div class="footer">
    <span>© 2026 DEATHOVERS</span>
    <span>POWERED BY GROQ + N8N</span>
  </div>
</Base>

<style>
  .content-area { padding: 32px 24px; }
  .section-title { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 32px; 
    color: #fff; 
    border-bottom: 2px solid var(--blood-red); 
    padding-bottom: 12px; 
    margin-bottom: 32px; 
  }
  
  .article-card {
    background: var(--outfield);
    border: 1px solid rgba(240,242,245,0.06);
    padding: 24px;
    margin-bottom: 16px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .article-card:hover {
    transform: translateY(-2px);
    border-color: var(--blood-red);
  }
  .meta-data { 
    font-family: 'JetBrains Mono', monospace; 
    font-size: 11px; 
    color: var(--blood-red); 
    margin-bottom: 12px; 
    text-transform: uppercase;
  }
  .card-title { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 28px; 
    color: #fff; 
    margin-bottom: 12px;
    text-decoration: none;
  }
  .card-excerpt {
    font-size: 14px; 
    line-height: 1.6; 
    color: rgba(240,242,245,0.7);
    margin-bottom: 16px;
  }
  .read-more {
    font-family: 'JetBrains Mono', monospace; 
    font-size: 12px; 
    color: var(--bail-amber); 
    text-decoration: none;
    font-weight: bold;
  }
  .read-more:hover { color: #fff; }
  .footer { 
    padding: 20px 24px; 
    border-top: 1px solid rgba(240,242,245,0.06); 
    display: flex; 
    justify-content: space-between; 
    margin-top: 60px; 
  }
  .footer span { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(240,242,245,0.3); }
</style>
