---
// src/pages/index.astro
import TelemetryDeck from '../components/TelemetryDeck.astro';

// Initialize clean fallback schema data structures to prevent build crashes if the API is offline
let matchData = {
  innings: 1,
  currentPhaseId: "PP1",
  matchMeta: {
    matchId: "loading_match",
    matchName: "Fetching Live Data...",
    date: "",
    status: "LIVE"
  },
  phaseLogs: [
    {
      phaseId: "PP1",
      title: "Establishing Live Telemetry Connection...",
      metrics: {
        rpo: "0.00",
        boundaries: 0,
        wickets: 0,
        pressureIndex: "INITIALIZING"
      },
      tacticalBlueprint: "Synchronizing analytical tracking modules with Render data streams. Standby for live match telemetry metrics.",
      winProbabilityDelta: 0
    }
  ]
};

// Fetch real-time data from your Python Render backend during the page request cycle
try {
  // Replace this placeholder link with your actual verified Render live-score URL
  const response = await fetch('https://deathovers-ai-engine.onrender.com/api/live-scores', {
    method: 'GET',
    headers: {
      'Cache-Control': 'no-cache',
      'Pragma': 'no-cache'
    }
  });
  
  if (response.ok) {
    matchData = await response.json();
  }
} catch (error) {
  console.error("Telemetry Deck Data Extraction Failure:", error);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DEATH OVERS // In-Play Telemetry Dashboard</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-[#07080a] text-white min-h-screen antialiased selection:bg-blue-500/30 selection:text-blue-200">
    
    <main class="max-w-5xl mx-auto px-4 py-8 md:py-12 flex flex-col gap-6">
      
      <header class="flex justify-between items-center border-b border-[#1e2330] pb-6">
        <div class="flex flex-col">
          <h1 class="text-2xl font-extrabold tracking-tighter bg-gradient-to-r from-white via-[#cbd5e1] to-[#64748b] bg-clip-text text-transparent uppercase font-sans">
            DEATH OVERS
          </h1>
          <p class="text-xs font-mono text-[#4f5e7c] uppercase tracking-widest mt-1">
            Elite Cricket Data Analytics Engine
          </p>
        </div>
        <div class="flex items-center space-x-2 bg-[#0d0f14] border border-[#1e2330] px-3 py-1.5 rounded-md">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span>
          <span class="text-[10px] font-mono tracking-wider text-emerald-400 font-bold uppercase">System Online</span>
        </div>
      </header>

      <section class="w-full">
        <TelemetryDeck 
          innings={matchData.innings} 
          currentPhaseId={matchData.currentPhaseId} 
          phaseLogs={matchData.phaseLogs} 
        />
      </section>

      <section class="mt-4 flex flex-col gap-4">
        <div class="flex items-center space-x-2 border-b border-[#1e2330]/60 pb-2">
          <h3 class="text-xs font-bold font-mono tracking-widest text-[#4f5e7c] uppercase">
            Historical Post-Mortem Reports
          </h3>
        </div>
        <div class="text-[#4f5e7c] text-xs font-mono py-8 text-center bg-[#0d0f14]/40 rounded border border-dashed border-[#1e2330]/60">
          Completed match analytical summaries will automatically populate here via your n8n publishing engine.
        </div>
      </section>

    </main>
    
  </body>
</html>

<style is:global>
  :root {
    --font-sans: 'Plus Jakarta Sans', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  html {
    font-family: var(--font-sans);
  }
  code, pre, .font-mono {
    font-family: var(--font-mono) !important;
  }
</style>
