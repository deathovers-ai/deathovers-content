---
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';

// Connect Press box cleanly to Astro Collections cache layer
const rawPosts = await getCollection('posts');
const articles = rawPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Press Box — DeathOvers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --pitch-black: #080A0F;
      --blood-red: #E8003A;
      --bail-amber: #F5A623;
      --crease-white: #F0F2F5;
      --outfield: #16191F;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--pitch-black);
      color: var(--crease-white);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      padding: 24px;
    }
    .page { width: 100%; max-width: 900px; background: var(--pitch-black); }
    .content-wrap { padding: 24px; }
    .page-title { font-family: 'Bebas Neue', sans-serif; font-size: 36px; letter-spacing: 0.05em; margin-bottom: 20px; color: var(--crease-white); border-bottom: 2px solid var(--blood-red); padding-bottom: 8px; }
    .articles-stack { display: flex; flex-direction: column; gap: 16px; }
    .article-card { background: var(--outfield); border: 1px solid rgba(240,242,245,0.08); border-radius: 4px; padding: 16px; transition: border-color 0.2s; }
    .article-card:hover { border-color: rgba(232,0,58,0.4); }
    .meta-tag { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--blood-red); margin-bottom: 6px; letter-spacing: 0.05em; text-transform: uppercase; }
    .article-title { font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: var(--crease-white); letter-spacing: 0.02em; line-height: 1.2; margin-bottom: 6px; text-transform: uppercase; }
    .article-date { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(240,242,245,0.4); }
    .empty-state { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: rgba(240,242,245,0.3); text-align: center; padding: 40px 0; }
    .footer { padding: 20px 24px; border-top: 1px solid rgba(240,242,245,0.06); display: flex; justify-content: space-between; margin-top: 40px; }
    .footer span { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(240,242,245,0.3); }
  </style>
</head>
<body>
  <div class="page">
    <Navbar />
    
    <div class="content-wrap">
      <h1 class="page-title">PRESS BOX BRIEFINGS</h1>
      
      <div class="articles-stack">
        {articles.length > 0 ? (
          articles.map((art) => (
            <div class="article-card">
              <div class="meta-tag">{art.data.category}</div>
              <div class="article-title">{art.data.title}</div>
              <div class="article-date">{art.data.date}</div>
            </div>
          ))
        ) : (
          <div class="empty-state">NO RECENT BULLETINS IN CHANNELS.</div>
        )}
      </div>
    </div>

    <div class="footer">
      <span>© 2026 DEATHOVERS</span>
      <span>POWERED BY GROQ + HIGHLIGHTLY</span>
    </div>
  </div>
</body>
</html>
