---
<div class="nav">
  <div>
    <a href="/" class="logo-link">
      <div class="logo-row">
        <span class="logo-death">DEATH</span>
        <span class="logo-overs">OVERS</span>
      </div>
    </a>
    <div class="tagline">EVERY BALL COUNTS.</div>
  </div>
  <div class="nav-links">
    <a href="/press-box">PRESS BOX</a>
    <a href="/tactical-sheets">TACTICAL SHEETS</a>
    <a href="/simulations">SIMULATIONS</a>
  </div>
</div>

<style>
  .nav {
    padding: 16px 24px;
    border-bottom: 1px solid rgba(240,242,245,0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo-link {
    text-decoration: none;
    display: inline-block;
  }
  .logo-row {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .logo-death {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--crease-white);
    line-height: 1;
  }
  .logo-overs {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--blood-red);
    line-height: 1;
  }
  .tagline {
    font-size: 9px;
    color: var(--bail-amber);
    letter-spacing: 0.1em;
    margin-top: 4px;
    font-family: 'JetBrains Mono', monospace;
  }
  .nav-links {
    display: flex;
    gap: 20px;
  }
  .nav-links a {
    font-size: 11px;
    color: rgba(240,242,245,0.6);
    text-decoration: none;
    letter-spacing: 0.05em;
    font-family: 'JetBrains Mono', monospace;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--blood-red);
  }
  @media (max-width: 640px) {
    .nav-links { display: none; }
  }
</style>
